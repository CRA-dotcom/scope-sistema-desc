# ─── Clerk (auth) ───────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Convex (frontend) ──────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
CONVEX_DEPLOYMENT=dev:your-project

# ─── Convex backend env (set via: npx convex env set KEY value) ──
# These live on the Convex deployment, NOT in Next.js. .env files do
# not reach Convex functions — you MUST `npx convex env set` each one.

# Clerk JWT issuer for the "convex" JWT template. Required: Convex
# auth fails hard at config time if missing.
CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-instance.clerk.accounts.dev

# App base URL used to build public links in emails. Required: code
# throws if missing (no localhost fallback — Convex sets
# NODE_ENV=production even on dev tier).
APP_URL=http://localhost:3000

# HMAC secret for quotation accept/decline tokens (min 32 chars).
# Generate with: openssl rand -base64 48. Use a DISTINCT value in prod.
QUOTATION_TOKEN_SECRET=

# Claude API for deliverable/contract generation.
ANTHROPIC_API_KEY=

# Resend (email). Platform-level fallback when an org has no
# integration configured. From-email must be a domain you own and
# have verified in Resend (SPF/DKIM/DMARC).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@businessinteligencehub.com
RESEND_FROM_NAME=Business Intelligence Hub
RESEND_WEBHOOK_SECRET=

# Internal ops/admin notification inbox for cron alerts (overdue
# deliverables, questionnaire-completed). If unset, those
# notifications are skipped (not sent to a placeholder domain).
OPS_NOTIFICATION_EMAIL=

# ─── Deploy / runtime ───────────────────────────────────────────
# Headless Chromium path for PDF generation. Set by the Dockerfile
# (Railway DOCKERFILE builder). Leave unset to use @sparticuz/chromium.
CHROMIUM_PATH=/usr/bin/chromium-browser

# QA-only seed gate. Set to "true" ONLY on the dev Convex deployment.
# Must NEVER be set in production.
QA_SEED_ALLOWED=
